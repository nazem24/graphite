<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Graphite light theme — warm monochrome glass floating over Mica. -->

    <SolidColorBrush x:Key="App.BackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="App.PanelBrush" Color="#A6FFFFFF"/>
    <SolidColorBrush x:Key="App.CardBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="App.ViewerBrush" Color="#40C9C9C4"/>

    <!-- glass surfaces -->
    <LinearGradientBrush x:Key="App.GlassBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#D9FFFFFF" Offset="0"/>
        <GradientStop Color="#AEFDFDFB" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="App.GlassBorderBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#F2FFFFFF" Offset="0"/>
        <GradientStop Color="#33B9B9B2" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="App.GlassSolidBrush" Color="#E8FCFCFA"/>
    <Color x:Key="App.ShadowColor">#000000</Color>

    <SolidColorBrush x:Key="App.StrokeBrush" Color="#D9D9D4"/>
    <SolidColorBrush x:Key="App.StrokeSoftBrush" Color="#E9E9E5"/>

    <SolidColorBrush x:Key="App.TextBrush" Color="#1B1B1A"/>
    <SolidColorBrush x:Key="App.TextSecondaryBrush" Color="#71716C"/>
    <SolidColorBrush x:Key="App.IconBrush" Color="#3B3B38"/>

    <SolidColorBrush x:Key="App.AccentBrush" Color="#2B2B29"/>
    <SolidColorBrush x:Key="App.AccentContrastBrush" Color="#FAFAF8"/>

    <!-- system accent fallbacks; ThemeService overrides these at runtime -->
    <Color x:Key="App.AccentSystemColor">#3E6DB5</Color>
    <SolidColorBrush x:Key="App.AccentSystemBrush" Color="#3E6DB5"/>
    <SolidColorBrush x:Key="App.AccentSoftBrush" Color="#2C3E6DB5"/>

    <SolidColorBrush x:Key="App.HoverBrush" Color="#0F000000"/>
    <SolidColorBrush x:Key="App.PressedBrush" Color="#1C000000"/>
    <SolidColorBrush x:Key="App.SelectionBrush" Color="#17000000"/>
    <SolidColorBrush x:Key="App.ToolCheckedBrush" Color="#24000000"/>

    <Color x:Key="App.SearchHighlightColor">#5B7A99</Color>
    <Color x:Key="App.SelectionColor">#4A6A88</Color>

</ResourceDictionary>
