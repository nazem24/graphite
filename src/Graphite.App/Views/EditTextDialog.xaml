<Window x:Class="Graphite.App.Views.EditTextDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner" SizeToContent="Height" Width="440"
        WindowStyle="ToolWindow" ResizeMode="NoResize" ShowInTaskbar="False"
        Background="{DynamicResource App.BackgroundBrush}"
        TextElement.Foreground="{DynamicResource App.TextBrush}"
        FontFamily="Segoe UI Variable, Segoe UI" FontSize="12.5">
    <StackPanel Margin="20">
        <TextBlock x:Name="PromptText" Style="{StaticResource Body}" TextWrapping="Wrap" Margin="0,0,0,10"/>
        <TextBox x:Name="ValueBox" FontSize="14" AcceptsReturn="True" TextWrapping="Wrap"
                 MinHeight="64" VerticalScrollBarVisibility="Auto"/>
        <DockPanel Margin="0,12,0,0">
            <TextBlock Text="Text size" Style="{StaticResource Caption}" VerticalAlignment="Center"/>
            <ComboBox x:Name="SizeBox" Width="110" Margin="10,0,0,0" HorizontalAlignment="Left"/>
        </DockPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Cancel" Style="{StaticResource GhostButton}" Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="OK" Style="{StaticResource AccentButton}" IsDefault="True" Click="Ok_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
