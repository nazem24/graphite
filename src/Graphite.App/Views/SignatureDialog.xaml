<Window x:Class="Graphite.App.Views.SignatureDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Draw your signature"
        WindowStartupLocation="CenterOwner" SizeToContent="Height" Width="560"
        WindowStyle="ToolWindow" ResizeMode="NoResize" ShowInTaskbar="False"
        Background="{DynamicResource App.BackgroundBrush}"
        TextElement.Foreground="{DynamicResource App.TextBrush}"
        FontFamily="Segoe UI Variable, Segoe UI" FontSize="12.5">
    <StackPanel Margin="20">
        <TextBlock Style="{StaticResource Body}" TextWrapping="Wrap" Margin="0,0,0,10"
                   Text="Draw with the mouse or a pen. The signature is saved so you can stamp it onto any page with the Signature tool."/>
        <Border Background="White" CornerRadius="10" BorderBrush="{DynamicResource App.StrokeBrush}"
                BorderThickness="1" Height="180" ClipToBounds="True">
            <Grid>
                <TextBlock Text="✕" Foreground="#D0D0CC" FontSize="11" Margin="12,0,0,14"
                           HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                <Rectangle Height="1" Fill="#E4E4E0" VerticalAlignment="Bottom" Margin="10,0,10,18"/>
                <Canvas x:Name="Pad" Background="Transparent"
                        MouseLeftButtonDown="Pad_Down" MouseMove="Pad_Move"
                        MouseLeftButtonUp="Pad_Up" MouseLeave="Pad_Up"/>
            </Grid>
        </Border>
        <DockPanel Margin="0,16,0,0">
            <Button DockPanel.Dock="Left" Content="Clear" Style="{StaticResource GhostButton}" Click="Clear_Click"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource GhostButton}" Margin="0,0,8,0" IsCancel="True"/>
                <Button x:Name="OkButton" Content="Save signature" Style="{StaticResource AccentButton}"
                        IsDefault="True" Click="Ok_Click" IsEnabled="False"/>
            </StackPanel>
        </DockPanel>
    </StackPanel>
</Window>
