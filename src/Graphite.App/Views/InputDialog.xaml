<Window x:Class="Graphite.App.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner" SizeToContent="Height" Width="380"
        WindowStyle="ToolWindow" ResizeMode="NoResize" ShowInTaskbar="False"
        Background="{DynamicResource App.BackgroundBrush}">
    <StackPanel Margin="18">
        <TextBlock x:Name="PromptText" Style="{StaticResource Body}" Margin="0,0,0,10" TextWrapping="Wrap"/>
        <TextBox x:Name="ValueBox" FontSize="14"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Style="{StaticResource GhostButton}" Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="OK" Style="{StaticResource AccentButton}" IsDefault="True" Click="Ok_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
