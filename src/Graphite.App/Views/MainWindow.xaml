<Window x:Class="Graphite.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Graphite.App.ViewModels"
        xmlns:ctrl="clr-namespace:Graphite.App.Controls"
        xmlns:conv="clr-namespace:Graphite.App.Converters"
        xmlns:core="clr-namespace:Graphite.Core;assembly=Graphite.Core"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Graphite" Width="1440" Height="900" MinWidth="960" MinHeight="560"
        AllowDrop="True" Drop="Window_Drop" PreviewKeyDown="Window_PreviewKeyDown"
        Background="{DynamicResource App.BackgroundBrush}"
        TextElement.Foreground="{DynamicResource App.TextBrush}"
        FontFamily="Segoe UI Variable, Segoe UI" FontSize="12.5">

    <shell:WindowChrome.WindowChrome>
        <!-- Custom chrome: keeps the native min/max/close buttons and Aero snap/shadow,
             but suppresses the default system icon + "Graphite" caption text. Our own
             glass command bar (below) supplies the visible branding/toolbar instead;
             the reserved strip above it is just a blank, draggable caption area. -->
        <shell:WindowChrome CaptionHeight="40"
                             GlassFrameThickness="-1"
                             CornerRadius="0"
                             ResizeBorderThickness="6"
                             UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToVisibilityConverter x:Key="InvBoolToVis" Invert="True"/>
        <conv:ZeroToVisibilityConverter x:Key="ZeroToVis"/>
        <conv:ZeroToVisibilityConverter x:Key="NonZeroToVis" Invert="True"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:HexToBrushConverter x:Key="HexToBrush"/>
        <conv:EnumToBoolConverter x:Key="EnumToBool"/>
        <conv:InvertBoolConverter x:Key="InvertBool"/>
        <conv:PlusOneConverter x:Key="PlusOne"/>
        <conv:ZoomToPercentConverter x:Key="ZoomToPercent"/>
        <conv:FileNameConverter x:Key="FileName"/>
        <conv:FileDirConverter x:Key="FileDir"/>

        <!-- ======================= document content ======================= -->
        <DataTemplate x:Key="DocTemplate" DataType="{x:Type vm:DocumentViewModel}">
            <Grid RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <TranslateTransform/>
                </Grid.RenderTransform>
                <Grid.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1"
                                                 Duration="0:0:0.22" EasingFunction="{StaticResource EaseOut}"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 From="8" To="0" Duration="0:0:0.24" EasingFunction="{StaticResource EaseOut}"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Grid.Triggers>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- ============ left sidebar: thumbnails / outline ============ -->
                <Border Grid.Column="0" Width="208" Margin="12,4,0,12"
                        Visibility="{Binding DataContext.ShowSidebar, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource GlassCard}">
                            <Style.Triggers>
                                <Trigger Property="Visibility" Value="Visible">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard Storyboard="{StaticResource FadeIn}"/>
                                    </Trigger.EnterActions>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="12,10">
                            <RadioButton x:Name="SideThumbs" Style="{StaticResource ToolToggle}" IsChecked="True"
                                         GroupName="Side" ToolTip="Page thumbnails">
                                <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Thumbs}"/>
                            </RadioButton>
                            <RadioButton x:Name="SideOutline" Style="{StaticResource ToolToggle}" Margin="4,0,0,0"
                                         GroupName="Side" ToolTip="Bookmarks / outline">
                                <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Outline}"/>
                            </RadioButton>
                        </StackPanel>

                        <Grid>
                            <!-- thumbnails -->
                            <ListBox Style="{StaticResource GList}" ItemContainerStyle="{StaticResource ThumbListItem}"
                                     ItemsSource="{Binding Pages}"
                                     SelectedIndex="{Binding CurrentPageIndex, Mode=OneWay}"
                                     SelectionChanged="Thumbs_SelectionChanged"
                                     VirtualizingPanel.ScrollUnit="Pixel"
                                     VirtualizingPanel.VirtualizationMode="Recycling"
                                     Visibility="{Binding IsChecked, ElementName=SideThumbs, Converter={StaticResource BoolToVis}}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Loaded="Thumb_Loaded" DataContextChanged="Thumb_DataContextChanged"
                                                    HorizontalAlignment="Center">
                                            <Border BorderBrush="{DynamicResource App.StrokeBrush}" BorderThickness="1"
                                                    Background="White" CornerRadius="4" ClipToBounds="True">
                                                <Image Source="{Binding Thumbnail}" Width="140"
                                                       Height="{Binding ThumbHeight}" Stretch="Uniform"/>
                                            </Border>
                                            <TextBlock Text="{Binding Label}" Style="{StaticResource Caption}"
                                                       HorizontalAlignment="Center" Margin="0,4,0,2"/>
                                            <StackPanel.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Rotate left"
                                                              Command="{Binding Path=DataContext.RotatePageLeftCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              CommandParameter="{Binding}"/>
                                                    <MenuItem Header="Rotate right"
                                                              Command="{Binding Path=DataContext.RotatePageRightCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              CommandParameter="{Binding}"/>
                                                    <Separator/>
                                                    <MenuItem Header="Move up"
                                                              Command="{Binding Path=DataContext.MovePageUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              CommandParameter="{Binding}"/>
                                                    <MenuItem Header="Move down"
                                                              Command="{Binding Path=DataContext.MovePageDownCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              CommandParameter="{Binding}"/>
                                                    <Separator/>
                                                    <MenuItem Header="Delete page"
                                                              Command="{Binding Path=DataContext.DeletePageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              CommandParameter="{Binding}"/>
                                                </ContextMenu>
                                            </StackPanel.ContextMenu>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- outline -->
                            <Grid Visibility="{Binding IsChecked, ElementName=SideOutline, Converter={StaticResource BoolToVis}}">
                                <TreeView ItemsSource="{Binding Outline}" Margin="4"
                                          SelectedItemChanged="Outline_SelectedItemChanged">
                                    <TreeView.ItemTemplate>
                                        <HierarchicalDataTemplate DataType="{x:Type core:OutlineNode}" ItemsSource="{Binding Children}">
                                            <TextBlock Text="{Binding Title}" Style="{StaticResource Body}" Margin="0,2"/>
                                        </HierarchicalDataTemplate>
                                    </TreeView.ItemTemplate>
                                </TreeView>
                                <TextBlock Text="No outline in this document" Style="{StaticResource Caption}"
                                           HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,24,0,0"
                                           Visibility="{Binding Outline.Count, Converter={StaticResource ZeroToVis}}"/>
                            </Grid>
                        </Grid>
                    </DockPanel>
                </Border>

                <!-- ============ page viewer ============ -->
                <Border Grid.Column="1" Margin="12,4,12,12" CornerRadius="16"
                        Background="{DynamicResource App.ViewerBrush}">
                    <Grid>
                        <ListBox x:Name="PagesHost"
                                 ItemsSource="{Binding VisiblePages}"
                                 Loaded="PagesHost_Loaded" DataContextChanged="PagesHost_DataContextChanged"
                                 ScrollViewer.ScrollChanged="PagesHost_ScrollChanged"
                                 PreviewMouseWheel="PagesHost_PreviewMouseWheel"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 VirtualizingPanel.ScrollUnit="Pixel"
                                 VirtualizingPanel.VirtualizationMode="Recycling">
                            <ListBox.Style>
                                <Style TargetType="ListBox" BasedOn="{StaticResource GList}">
                                    <Style.Triggers>
                                        <!-- Two-page spread lays its pair out side by side. -->
                                        <DataTrigger Binding="{Binding Layout}" Value="Spread">
                                            <Setter Property="ItemsPanel">
                                                <Setter.Value>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal"
                                                                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </ItemsPanelTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Layout}" Value="Single">
                                            <Setter Property="ItemsPanel">
                                                <Setter.Value>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel VerticalAlignment="Center"/>
                                                    </ItemsPanelTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="Focusable" Value="False"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="6" HorizontalAlignment="Center"
                                          Loaded="PageRoot_Loaded" DataContextChanged="PageRoot_DataContextChanged">
                                        <!-- The drop shadow sits on an empty sibling border rather than on the
                                             content border: a BitmapEffect re-renders its entire subtree into an
                                             intermediate surface whenever anything inside invalidates, so putting
                                             the page image + live annotation layer under the effect made every
                                             mouse-move while drawing re-run an 18px blur over the whole page. -->
                                        <Border BorderThickness="1"
                                                Width="{Binding DisplayWidth}" Height="{Binding DisplayHeight}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Doc.InvertPages}" Value="True">
                                                            <Setter Property="Background" Value="#141416"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="18" ShadowDepth="3" Direction="270" Opacity="0.28"/>
                                            </Border.Effect>
                                        </Border>
                                        <Border BorderBrush="#33000000" BorderThickness="1"
                                                Width="{Binding DisplayWidth}" Height="{Binding DisplayHeight}">
                                            <Grid>
                                                <Image Source="{Binding Image}" Stretch="Fill"/>
                                                <ctrl:AnnotationLayer/>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- floating page controls -->
                        <Border Style="{StaticResource GlassPill}" VerticalAlignment="Bottom"
                                HorizontalAlignment="Center" Margin="0,0,0,16" Padding="6,3"
                                Background="{DynamicResource App.CardBrush}"
                                BorderBrush="{DynamicResource App.StrokeBrush}">
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource IconButton}" Padding="5" Click="PrevPage_Click" ToolTip="Previous page">
                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.ChevronLeft}"
                                          Width="11" Height="11" Stretch="Uniform"/>
                                </Button>
                                <Button Style="{StaticResource IconButton}" Padding="6,4" BorderThickness="0"
                                        Command="{Binding DataContext.GoToPageDialogCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="Go to page… (Ctrl+G)">
                                    <TextBlock Text="{Binding PageStatus}" FontSize="12" Foreground="{DynamicResource App.TextBrush}"/>
                                </Button>
                                <Button Style="{StaticResource IconButton}" Padding="5" Click="NextPage_Click" ToolTip="Next page">
                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.ChevronRight}"
                                          Width="11" Height="11" Stretch="Uniform"/>
                                </Button>

                                <Rectangle Style="{StaticResource ToolSep}" Height="14"/>

                                <Button Style="{StaticResource IconButton}" Padding="5"
                                        Command="{Binding DataContext.ZoomOutCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="Zoom out (Ctrl+-)">
                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.ZoomOut}"
                                          Width="13" Height="13" Stretch="Uniform"/>
                                </Button>
                                <TextBlock Text="{Binding Zoom, Converter={StaticResource ZoomToPercent}}"
                                           VerticalAlignment="Center" MinWidth="40" TextAlignment="Center" FontSize="12"
                                           Foreground="{DynamicResource App.TextBrush}"/>
                                <Button Style="{StaticResource IconButton}" Padding="5"
                                        Command="{Binding DataContext.ZoomInCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="Zoom in (Ctrl++)">
                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.ZoomIn}"
                                          Width="13" Height="13" Stretch="Uniform"/>
                                </Button>
                                <Button Style="{StaticResource IconButton}" Padding="5" Click="FitWidth_Click" ToolTip="Fit page width">
                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.FitWidth}"
                                          Width="13" Height="13" Stretch="Uniform"/>
                                </Button>

                                <Rectangle Style="{StaticResource ToolSep}" Height="14"/>

                                <RadioButton Style="{StaticResource ToolToggle}" Padding="5" GroupName="Layout"
                                             ToolTip="Continuous scrolling"
                                             IsChecked="{Binding Layout, Converter={StaticResource EnumToBool}, ConverterParameter=Continuous}">
                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Continuous}"
                                          Width="12" Height="12" Stretch="Uniform"/>
                                </RadioButton>
                                <RadioButton Style="{StaticResource ToolToggle}" Padding="5" GroupName="Layout"
                                             ToolTip="Single page"
                                             IsChecked="{Binding Layout, Converter={StaticResource EnumToBool}, ConverterParameter=Single}">
                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.SinglePage}"
                                          Width="12" Height="12" Stretch="Uniform"/>
                                </RadioButton>
                                <RadioButton Style="{StaticResource ToolToggle}" Padding="5" GroupName="Layout"
                                             ToolTip="Two-page spread"
                                             IsChecked="{Binding Layout, Converter={StaticResource EnumToBool}, ConverterParameter=Spread}">
                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Spread}"
                                          Width="12" Height="12" Stretch="Uniform"/>
                                </RadioButton>

                                <Rectangle Style="{StaticResource ToolSep}" Height="14"/>

                                <ToggleButton Style="{StaticResource IconButton}" Padding="5"
                                              IsChecked="{Binding InvertPages}"
                                              ToolTip="Invert page colors">
                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Invert}"
                                          Width="13" Height="13" Stretch="Uniform"/>
                                </ToggleButton>
                                <Button Style="{StaticResource IconButton}" Padding="5"
                                        Command="{Binding DataContext.ToggleFullscreenCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="Fullscreen reading (F11)">
                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Fullscreen}"
                                          Width="13" Height="13" Stretch="Uniform"/>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- busy overlay -->
                        <Border Background="#66000000" CornerRadius="16"
                                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="Visibility" Value="Visible">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard Storyboard="{StaticResource FadeIn}"/>
                                            </Trigger.EnterActions>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Border Background="{DynamicResource App.GlassSolidBrush}"
                                    HorizontalAlignment="Center" VerticalAlignment="Center" Padding="26,20"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform/>
                                </Border.RenderTransform>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource GlassCard}">
                                        <Style.Triggers>
                                            <Trigger Property="IsVisible" Value="True">
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard Storyboard="{StaticResource PopIn}"/>
                                                </Trigger.EnterActions>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <ProgressBar IsIndeterminate="True" Width="220" Height="4"/>
                                    <TextBlock Text="{Binding BusyText}" Style="{StaticResource Body}"
                                               Margin="0,10,0,0" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Border>
                    </Grid>
                </Border>

                <!-- ============ right panel: comments / search ============ -->
                <Border Grid.Column="2" Width="292" Margin="0,4,12,12"
                        Visibility="{Binding DataContext.ShowInspector, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource GlassCard}">
                            <Style.Triggers>
                                <Trigger Property="Visibility" Value="Visible">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard Storyboard="{StaticResource FadeIn}"/>
                                    </Trigger.EnterActions>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="12,10">
                            <RadioButton x:Name="TabComments" Style="{StaticResource ToolToggle}" IsChecked="True"
                                         GroupName="Inspector" ToolTip="Comments &amp; markup">
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Note}"/>
                                    <TextBlock Text="Markup" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="TabSearch" Style="{StaticResource ToolToggle}" Margin="4,0,0,0"
                                         GroupName="Inspector" Loaded="SearchRadio_Loaded" ToolTip="Search in document">
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Search}"/>
                                    <TextBlock Text="Search" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>

                        <Grid>
                            <!-- markup summary -->
                            <DockPanel Visibility="{Binding IsChecked, ElementName=TabComments, Converter={StaticResource BoolToVis}}">
                                <TextBlock DockPanel.Dock="Top" Margin="14,2,14,8" Style="{StaticResource Caption}"
                                           Text="{Binding Annotations.Count, StringFormat={}{0} annotation(s) in this document}"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Annotations}" Margin="10,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource App.CardBrush}"
                                                        BorderBrush="{DynamicResource App.StrokeSoftBrush}" BorderThickness="1"
                                                        CornerRadius="10" Padding="10" Margin="0,0,0,8">
                                                    <Border.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick" Command="{Binding GoToCommand}"/>
                                                    </Border.InputBindings>
                                                    <StackPanel>
                                                        <DockPanel>
                                                            <Rectangle Width="10" Height="10" RadiusX="3" RadiusY="3"
                                                                       Fill="{Binding Swatch}" VerticalAlignment="Center"/>
                                                            <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}"
                                                                    Command="{Binding DeleteCommand}" Padding="3" ToolTip="Delete annotation">
                                                                <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Close}"
                                                                      Width="10" Height="10" Stretch="Uniform"/>
                                                            </Button>
                                                            <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Style="{StaticResource Body}">
                                                                <Run Text="{Binding KindLabel, Mode=OneWay}" FontWeight="SemiBold"/>
                                                                <Run Text="{Binding PageLabel, Mode=OneWay}" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                                                            </TextBlock>
                                                        </DockPanel>
                                                        <TextBlock Style="{StaticResource Caption}" Margin="0,3,0,0">
                                                            <Run Text="{Binding Author, Mode=OneWay}"/> · <Run Text="{Binding When, Mode=OneWay}"/>
                                                        </TextBlock>
                                                        <TextBox Text="{Binding Contents, UpdateSourceTrigger=LostFocus}"
                                                                 Margin="0,7,0,0" TextWrapping="Wrap" AcceptsReturn="True"
                                                                 MinHeight="26" FontSize="12"
                                                                 ToolTip="Comment text"/>
                                                        <ItemsControl ItemsSource="{Binding Replies}" Margin="10,6,0,0">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border BorderBrush="{DynamicResource App.StrokeSoftBrush}"
                                                                            BorderThickness="1,0,0,0" Padding="8,2,0,4">
                                                                        <StackPanel>
                                                                            <TextBlock Style="{StaticResource Caption}">
                                                                                <Run Text="{Binding Author, Mode=OneWay}" FontWeight="SemiBold"/>
                                                                            </TextBlock>
                                                                            <TextBlock Text="{Binding Text}" Style="{StaticResource Body}"
                                                                                       TextWrapping="Wrap" FontSize="12"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <DockPanel Margin="10,6,0,0">
                                                            <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}"
                                                                    Command="{Binding AddReplyCommand}" Margin="4,0,0,0" ToolTip="Reply">
                                                                <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Reply}"
                                                                      Width="13" Height="13" Stretch="Uniform"/>
                                                            </Button>
                                                            <TextBox Text="{Binding ReplyDraft, UpdateSourceTrigger=PropertyChanged}"
                                                                     FontSize="12" ToolTip="Write a reply"/>
                                                        </DockPanel>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>

                            <!-- search -->
                            <DockPanel Visibility="{Binding IsChecked, ElementName=TabSearch, Converter={StaticResource BoolToVis}}">
                                <StackPanel DockPanel.Dock="Top" Margin="14,2,14,6">
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}"
                                                Click="SearchNext_Click" ToolTip="Next match (F3)">
                                            <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.ChevronDown}"/>
                                        </Button>
                                        <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}"
                                                Click="SearchPrev_Click" ToolTip="Previous match (Shift+F3)">
                                            <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.ChevronUp}"/>
                                        </Button>
                                        <TextBox Loaded="SearchBox_Loaded" KeyDown="SearchBox_KeyDown"
                                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="Search text"/>
                                    </DockPanel>
                                    <TextBlock Text="{Binding MatchStatus}" Style="{StaticResource Caption}" Margin="2,6,0,0"/>
                                </StackPanel>
                                <ListBox Style="{StaticResource GList}" ItemsSource="{Binding SearchResults}"
                                         SelectionChanged="Results_SelectionChanged" Margin="8,0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource Caption}"
                                                           Text="{Binding PageIndex, Converter={StaticResource PlusOne}, StringFormat={}Page {0}}"/>
                                                <TextBlock Text="{Binding Snippet}" Style="{StaticResource Body}"
                                                           TextWrapping="Wrap" FontSize="12"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Grid>
                    </DockPanel>
                </Border>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Modifiers="Ctrl" Key="O" Command="{Binding OpenCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="S" Command="{Binding SaveCommand}"/>
        <KeyBinding Modifiers="Ctrl+Shift" Key="S" Command="{Binding SaveAsCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="P" Command="{Binding PrintCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="K" Command="{Binding OpenPaletteCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="W" Command="{Binding CloseDocumentCommand}"
                    CommandParameter="{Binding SelectedDocument}"/>
        <KeyBinding Modifiers="Ctrl" Key="G" Command="{Binding GoToPageDialogCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="OemPlus" Command="{Binding ZoomInCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="OemMinus" Command="{Binding ZoomOutCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ======================= floating glass command bar ======================= -->
        <Border Grid.Row="0" Style="{StaticResource GlassCard}" CornerRadius="14" Margin="12,46,12,6"
                Visibility="{Binding IsFullscreen, Converter={StaticResource InvBoolToVis}}"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <TranslateTransform/>
            </Border.RenderTransform>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard Storyboard="{StaticResource RiseIn}"/>
                </EventTrigger>
            </Border.Triggers>
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="3" Direction="270" Opacity="0.18"/>
            </Border.Effect>
            <DockPanel Margin="10,6">
                <!-- brand -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0,12,0">
                    <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Logo}"
                          Stroke="{DynamicResource App.TextBrush}" StrokeThickness="1.4"/>
                    <TextBlock Text="Graphite" FontWeight="SemiBold" FontSize="14" Margin="8,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- right side -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource IconButton}" Command="{Binding OpenPaletteCommand}"
                            ToolTip="Command palette (Ctrl+K)">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Command}"/>
                    </Button>
                    <ToggleButton Style="{StaticResource IconButton}" IsChecked="{Binding ShowSidebar}" ToolTip="Toggle sidebar">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Sidebar}"/>
                    </ToggleButton>
                    <ToggleButton Style="{StaticResource IconButton}" IsChecked="{Binding ShowInspector}" ToolTip="Toggle markup panel">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Inspector}"/>
                    </ToggleButton>
                    <Button Style="{StaticResource IconButton}" Command="{Binding ToggleThemeCommand}" ToolTip="Switch light / dark theme">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Theme}"
                              RenderTransformOrigin="0.5,0.5">
                            <Path.RenderTransform>
                                <RotateTransform/>
                            </Path.RenderTransform>
                            <Path.Triggers>
                                <EventTrigger RoutedEvent="Mouse.PreviewMouseDown">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                             By="150" Duration="0:0:0.28" EasingFunction="{StaticResource EaseOutSoft}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Path.Triggers>
                        </Path>
                    </Button>
                </StackPanel>

                <!-- center: file + tools -->
                <StackPanel Orientation="Horizontal">
                    <!-- File: open/save/print/security/properties, collapsed into one menu -->
                    <Button Style="{StaticResource IconButton}" Click="OrganizeMenu_Click" ToolTip="File">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Open}"/>
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.ChevronDown}"
                                  Width="10" Height="10" Stretch="Uniform" Margin="3,0,0,0"/>
                        </StackPanel>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Open… (Ctrl+O)" Command="{Binding OpenCommand}"/>
                                <MenuItem Header="Open from OneDrive" Command="{Binding OpenOneDriveCommand}"/>
                                <Separator/>
                                <MenuItem Header="Save (Ctrl+S)" Command="{Binding SaveCommand}"/>
                                <MenuItem Header="Save As… (Ctrl+Shift+S)" Command="{Binding SaveAsCommand}"/>
                                <MenuItem Header="Save encrypted copy…" Command="{Binding SaveEncryptedCopyCommand}"/>
                                <Separator/>
                                <MenuItem Header="Print… (Ctrl+P)" Command="{Binding PrintCommand}"/>
                                <Separator/>
                                <MenuItem Header="Document properties" Command="{Binding ShowPropertiesCommand}"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                    <StackPanel Orientation="Horizontal">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="IsEnabled" Value="True"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedDocument}" Value="{x:Null}">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <Rectangle Style="{StaticResource ToolSep}"/>
                        <TextBlock Text="Edit" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.65"/>

                        <Button Style="{StaticResource IconButton}" Command="{Binding UndoCommand}" ToolTip="Undo (Ctrl+Z)">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Undo}"/>
                        </Button>
                        <Button Style="{StaticResource IconButton}" Command="{Binding RedoCommand}" ToolTip="Redo (Ctrl+Y)">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Redo}"/>
                        </Button>

                        <Rectangle Style="{StaticResource ToolSep}"/>
                        <TextBlock Text="Pages" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.65"/>

                        <!-- organize menu -->
                        <Button Style="{StaticResource IconButton}" Click="OrganizeMenu_Click" ToolTip="Organize pages">
                            <StackPanel Orientation="Horizontal">
                                <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.InsertPage}"/>
                                <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.ChevronDown}"
                                      Width="10" Height="10" Stretch="Uniform" Margin="3,0,0,0"/>
                            </StackPanel>
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Merge PDFs…" Command="{Binding MergeCommand}"/>
                                    <MenuItem Header="Split into single pages…" Command="{Binding SplitCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="Insert pages from PDF…" Command="{Binding InsertPagesCommand}"/>
                                    <MenuItem Header="Insert blank page" Command="{Binding InsertBlankPageCommand}"/>
                                    <MenuItem Header="Delete pages…" Command="{Binding DeletePagesCommand}"/>
                                    <MenuItem Header="Extract pages…" Command="{Binding ExtractPagesCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="Rotate current page left" Command="{Binding RotatePageLeftCommand}"/>
                                    <MenuItem Header="Rotate current page right" Command="{Binding RotatePageRightCommand}"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>

                        <!-- export / convert menu (OCR lives here too) -->
                        <Button Style="{StaticResource IconButton}" Click="OrganizeMenu_Click" ToolTip="Export / convert">
                            <StackPanel Orientation="Horizontal">
                                <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Export}"/>
                                <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.ChevronDown}"
                                      Width="10" Height="10" Stretch="Uniform" Margin="3,0,0,0"/>
                            </StackPanel>
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Export to Word (.docx)…" Command="{Binding ExportWordCommand}"/>
                                    <MenuItem Header="Export to Excel (.xlsx)…" Command="{Binding ExportExcelCommand}"/>
                                    <MenuItem Header="Export to PowerPoint (.pptx)…" Command="{Binding ExportPowerPointCommand}"/>
                                    <MenuItem Header="Export pages as images…" Command="{Binding ExportImagesCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="Recognize text (OCR)…" Command="{Binding RunOcrCommand}"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>

                        <Rectangle Style="{StaticResource ToolSep}"/>
                        <TextBlock Text="Tools" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.65"/>

                        <!-- annotation tools -->
                        <RadioButton Style="{StaticResource ToolToggle}" GroupName="Tools" ToolTip="Select"
                                     IsChecked="{Binding SelectedDocument.ActiveTool, Converter={StaticResource EnumToBool}, ConverterParameter=Select}">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Select}"/>
                        </RadioButton>
                        <!-- Highlight: one button. Click activates it; click again (already active)
                             or right-click opens the text-select / freehand mode menu. -->
                        <RadioButton Style="{StaticResource ToolToggle}" GroupName="Tools"
                                     ToolTip="Highlight"
                                     PreviewMouseLeftButtonDown="HighlightTool_PreviewMouseDown"
                                     IsChecked="{Binding SelectedDocument.ActiveTool, Converter={StaticResource EnumToBool}, ConverterParameter=Highlight}">
                            <Grid Width="16" Height="16">
                                <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Highlight}"/>
                                <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.ChevronDown}"
                                      Width="7" Height="7" Stretch="Uniform" StrokeThickness="1.1" Opacity="0.8"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-3,-3"/>
                            </Grid>
                            <RadioButton.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Select text to highlight" Command="{Binding SetHighlightModeCommand}" CommandParameter="text"/>
                                    <MenuItem Header="Freehand highlighting" Command="{Binding SetHighlightModeCommand}" CommandParameter="freehand"/>
                                </ContextMenu>
                            </RadioButton.ContextMenu>
                        </RadioButton>

                        <RadioButton Style="{StaticResource ToolToggle}" GroupName="Tools" ToolTip="Underline"
                                     IsChecked="{Binding SelectedDocument.ActiveTool, Converter={StaticResource EnumToBool}, ConverterParameter=Underline}">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Underline}"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource ToolToggle}" GroupName="Tools" ToolTip="Strikethrough"
                                     IsChecked="{Binding SelectedDocument.ActiveTool, Converter={StaticResource EnumToBool}, ConverterParameter=StrikeOut}">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Strike}"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource ToolToggle}" GroupName="Tools" ToolTip="Draw"
                                     IsChecked="{Binding SelectedDocument.ActiveTool, Converter={StaticResource EnumToBool}, ConverterParameter=Ink}">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Ink}"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource ToolToggle}" GroupName="Tools"
                                     ToolTip="Eraser"
                                     IsChecked="{Binding SelectedDocument.ActiveTool, Converter={StaticResource EnumToBool}, ConverterParameter=Eraser}">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Eraser}"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource ToolToggle}" GroupName="Tools" ToolTip="Rectangle"
                                     IsChecked="{Binding SelectedDocument.ActiveTool, Converter={StaticResource EnumToBool}, ConverterParameter=Rect}">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Rect}"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource ToolToggle}" GroupName="Tools" ToolTip="Ellipse"
                                     IsChecked="{Binding SelectedDocument.ActiveTool, Converter={StaticResource EnumToBool}, ConverterParameter=Ellipse}">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Ellipse}"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource ToolToggle}" GroupName="Tools"
                                     ToolTip="Add text"
                                     IsChecked="{Binding SelectedDocument.ActiveTool, Converter={StaticResource EnumToBool}, ConverterParameter=Text}">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.TextTool}"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource ToolToggle}" GroupName="Tools" ToolTip="Arrow"
                                     IsChecked="{Binding SelectedDocument.ActiveTool, Converter={StaticResource EnumToBool}, ConverterParameter=Arrow}">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Arrow}"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource ToolToggle}" GroupName="Tools"
                                     ToolTip="Signature"
                                     IsChecked="{Binding SelectedDocument.ActiveTool, Converter={StaticResource EnumToBool}, ConverterParameter=Signature}">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Signature}"/>
                        </RadioButton>
                        <Button Style="{StaticResource IconButton}" Click="OrganizeMenu_Click" ToolTip="Edit signature">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.ChevronDown}"
                                  Width="10" Height="10" Stretch="Uniform"/>
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Edit signature…" Command="{Binding EditSignatureCommand}"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>

                        <Rectangle Style="{StaticResource ToolSep}"/>
                        <TextBlock Text="Style" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.65"/>

                        <!-- markup color -->
                        <Button Style="{StaticResource IconButton}" Click="OrganizeMenu_Click"
                                ToolTip="Color for the active tool">
                            <Border Width="16" Height="16" CornerRadius="8"
                                    BorderBrush="{DynamicResource App.StrokeBrush}" BorderThickness="1"
                                    Background="{Binding SelectedDocument.ActiveColorHex, Converter={StaticResource HexToBrush}}"/>
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Command="{Binding SetToolColorCommand}" CommandParameter="#F2C744">
                                        <MenuItem.Header><StackPanel Orientation="Horizontal"><Rectangle Width="14" Height="14" RadiusX="7" RadiusY="7" Fill="#F2C744"/><TextBlock Text="Yellow" Margin="8,0,0,0"/></StackPanel></MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Command="{Binding SetToolColorCommand}" CommandParameter="#E8853C">
                                        <MenuItem.Header><StackPanel Orientation="Horizontal"><Rectangle Width="14" Height="14" RadiusX="7" RadiusY="7" Fill="#E8853C"/><TextBlock Text="Orange" Margin="8,0,0,0"/></StackPanel></MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Command="{Binding SetToolColorCommand}" CommandParameter="#C24444">
                                        <MenuItem.Header><StackPanel Orientation="Horizontal"><Rectangle Width="14" Height="14" RadiusX="7" RadiusY="7" Fill="#C24444"/><TextBlock Text="Red" Margin="8,0,0,0"/></StackPanel></MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Command="{Binding SetToolColorCommand}" CommandParameter="#C75E9A">
                                        <MenuItem.Header><StackPanel Orientation="Horizontal"><Rectangle Width="14" Height="14" RadiusX="7" RadiusY="7" Fill="#C75E9A"/><TextBlock Text="Pink" Margin="8,0,0,0"/></StackPanel></MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Command="{Binding SetToolColorCommand}" CommandParameter="#3E6DB5">
                                        <MenuItem.Header><StackPanel Orientation="Horizontal"><Rectangle Width="14" Height="14" RadiusX="7" RadiusY="7" Fill="#3E6DB5"/><TextBlock Text="Blue" Margin="8,0,0,0"/></StackPanel></MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Command="{Binding SetToolColorCommand}" CommandParameter="#2E8C83">
                                        <MenuItem.Header><StackPanel Orientation="Horizontal"><Rectangle Width="14" Height="14" RadiusX="7" RadiusY="7" Fill="#2E8C83"/><TextBlock Text="Teal" Margin="8,0,0,0"/></StackPanel></MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Command="{Binding SetToolColorCommand}" CommandParameter="#4E9C51">
                                        <MenuItem.Header><StackPanel Orientation="Horizontal"><Rectangle Width="14" Height="14" RadiusX="7" RadiusY="7" Fill="#4E9C51"/><TextBlock Text="Green" Margin="8,0,0,0"/></StackPanel></MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Command="{Binding SetToolColorCommand}" CommandParameter="#7B5EC7">
                                        <MenuItem.Header><StackPanel Orientation="Horizontal"><Rectangle Width="14" Height="14" RadiusX="7" RadiusY="7" Fill="#7B5EC7"/><TextBlock Text="Purple" Margin="8,0,0,0"/></StackPanel></MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Command="{Binding SetToolColorCommand}" CommandParameter="#3B3B38">
                                        <MenuItem.Header><StackPanel Orientation="Horizontal"><Rectangle Width="14" Height="14" RadiusX="7" RadiusY="7" Fill="#3B3B38"/><TextBlock Text="Graphite" Margin="8,0,0,0"/></StackPanel></MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Command="{Binding SetToolColorCommand}" CommandParameter="#111111">
                                        <MenuItem.Header><StackPanel Orientation="Horizontal"><Rectangle Width="14" Height="14" RadiusX="7" RadiusY="7" Fill="#111111"/><TextBlock Text="Black" Margin="8,0,0,0"/></StackPanel></MenuItem.Header>
                                    </MenuItem>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>

                        <!-- stroke thickness -->
                        <Button Style="{StaticResource IconButton}" Click="OrganizeMenu_Click"
                                ToolTip="Line thickness">
                            <TextBlock Text="{Binding SelectedDocument.ActiveStrokeWidth, StringFormat={}{0} pt}"
                                       FontSize="11" VerticalAlignment="Center"/>
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Hairline — 1 pt" Command="{Binding SetToolWidthCommand}" CommandParameter="1"/>
                                    <MenuItem Header="Fine — 1.5 pt" Command="{Binding SetToolWidthCommand}" CommandParameter="1.5"/>
                                    <MenuItem Header="Regular — 2 pt" Command="{Binding SetToolWidthCommand}" CommandParameter="2"/>
                                    <MenuItem Header="Bold — 3 pt" Command="{Binding SetToolWidthCommand}" CommandParameter="3"/>
                                    <MenuItem Header="Heavy — 4.5 pt" Command="{Binding SetToolWidthCommand}" CommandParameter="4.5"/>
                                    <MenuItem Header="Marker — 6 pt" Command="{Binding SetToolWidthCommand}" CommandParameter="6"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>

                        <Rectangle Style="{StaticResource ToolSep}"/>
                        <TextBlock Text="Content" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.65"/>

                        <RadioButton Style="{StaticResource ToolToggle}" GroupName="Tools"
                                     ToolTip="Edit text"
                                     IsChecked="{Binding SelectedDocument.ActiveTool, Converter={StaticResource EnumToBool}, ConverterParameter=EditText}">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.EditText}"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource ToolToggle}" GroupName="Tools"
                                     ToolTip="Place image"
                                     IsChecked="{Binding SelectedDocument.ActiveTool, Converter={StaticResource EnumToBool}, ConverterParameter=PlaceImage}">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Image}"/>
                        </RadioButton>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ======================= custom caption buttons ======================= -->
        <!-- WindowChrome's built-in UseAeroCaptionButtons doesn't reliably draw anything
             on modern Windows, so minimize/maximize/close are drawn here by hand. -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Height="40" Visibility="{Binding IsFullscreen, Converter={StaticResource InvBoolToVis}}">
            <Button Style="{StaticResource IconButton}" Padding="12,13" Focusable="False"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    Click="MinimizeButton_Click" ToolTip="Minimize">
                <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.WinMinimize}" Width="11" Height="11" Stretch="Uniform"/>
            </Button>
            <Button x:Name="MaximizeRestoreButton" Style="{StaticResource IconButton}" Padding="12,13" Focusable="False"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    Click="MaximizeRestoreButton_Click" ToolTip="Maximize">
                <Path x:Name="MaximizeRestoreIcon" Style="{StaticResource IconPath}" Data="{StaticResource Icon.WinMaximize}" Width="11" Height="11" Stretch="Uniform"/>
            </Button>
            <Button Style="{StaticResource CaptionCloseButton}" Padding="12,13" Focusable="False"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    Click="CloseButton_Click" ToolTip="Close">
                <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Close}" Width="11" Height="11" Stretch="Uniform"/>
            </Button>
        </StackPanel>

        <!-- ======================= documents ======================= -->
        <TabControl Grid.Row="1" Style="{StaticResource DocTabControl}"
                    ItemsSource="{Binding Documents}" SelectedItem="{Binding SelectedDocument}"
                    ItemContainerStyle="{StaticResource DocTab}"
                    ContentTemplate="{StaticResource DocTemplate}"
                    Visibility="{Binding Documents.Count, Converter={StaticResource NonZeroToVis}}">
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Title}" MaxWidth="180" TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="●" FontSize="8" Margin="6,0,0,0" VerticalAlignment="Center"
                                   Foreground="{DynamicResource App.AccentSystemBrush}"
                                   Visibility="{Binding IsDirty, Converter={StaticResource BoolToVis}}"/>
                        <Button Style="{StaticResource IconButton}" Padding="3" Margin="6,0,0,0" ToolTip="Close (Ctrl+W)"
                                Command="{Binding DataContext.CloseDocumentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Close}"
                                  Width="9" Height="9" Stretch="Uniform"/>
                        </Button>
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>
        </TabControl>

        <!-- ======================= start page ======================= -->
        <Grid Grid.Row="1" Visibility="{Binding Documents.Count, Converter={StaticResource ZeroToVis}}">
            <Border Style="{StaticResource GlassCard}" Width="480" HorizontalAlignment="Center"
                    VerticalAlignment="Center" Padding="36,40" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TranslateTransform/>
                </Border.RenderTransform>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard Storyboard="{StaticResource RiseIn}"/>
                    </EventTrigger>
                </Border.Triggers>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="32" ShadowDepth="6" Direction="270" Opacity="0.18"/>
                </Border.Effect>
                <StackPanel>
                    <Path Data="{StaticResource Icon.Logo}" Stroke="{DynamicResource App.TextBrush}"
                          StrokeThickness="2" Width="16" Height="16" Stretch="Uniform"
                          HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <ScaleTransform ScaleX="3.4" ScaleY="3.4"/>
                        </Path.RenderTransform>
                    </Path>
                    <TextBlock Text="Graphite" Style="{StaticResource H1}" HorizontalAlignment="Center" Margin="0,34,0,2"/>
                    <TextBlock Text="PDF, precisely." Style="{StaticResource Caption}" FontSize="13" HorizontalAlignment="Center"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,26,0,0">
                        <Button Style="{StaticResource AccentButton}" Command="{Binding OpenCommand}" Content="Open a document…"/>
                        <Button Style="{StaticResource GhostButton}" Command="{Binding OpenOneDriveCommand}"
                                Content="From OneDrive" Margin="10,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="…or drop PDF or Office files anywhere in this window."
                               Style="{StaticResource Caption}" HorizontalAlignment="Center" Margin="0,12,0,0"/>

                    <TextBlock Text="RECENT" Style="{StaticResource Caption}" Margin="6,30,0,6" FontSize="10"
                               Visibility="{Binding RecentFiles.Count, Converter={StaticResource NonZeroToVis}}"/>
                    <ListBox Style="{StaticResource GList}" ItemsSource="{Binding RecentFiles}" MaxHeight="220"
                             SelectionChanged="RecentList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2,1">
                                    <TextBlock Text="{Binding Converter={StaticResource FileName}}"
                                               Style="{StaticResource Body}" FontSize="12.5"/>
                                    <TextBlock Text="{Binding Converter={StaticResource FileDir}}"
                                               Style="{StaticResource Caption}" Margin="0,1,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ======================= command palette ======================= -->
        <Grid Grid.RowSpan="2" Background="#30000000"
              Visibility="{Binding IsPaletteOpen, Converter={StaticResource BoolToVis}}"
              MouseLeftButtonDown="PaletteScrim_Click">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <Trigger Property="Visibility" Value="Visible">
                            <Trigger.EnterActions>
                                <BeginStoryboard Storyboard="{StaticResource FadeIn}"/>
                            </Trigger.EnterActions>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border x:Name="PaletteCard" Background="{DynamicResource App.GlassSolidBrush}"
                    Width="560" VerticalAlignment="Top" Margin="0,88,0,0" Padding="10"
                    RenderTransformOrigin="0.5,0">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource GlassCard}">
                        <Style.Triggers>
                            <Trigger Property="IsVisible" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard Storyboard="{StaticResource PopIn}"/>
                                </Trigger.EnterActions>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.RenderTransform>
                    <ScaleTransform/>
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="36" ShadowDepth="8" Direction="270" Opacity="0.35"/>
                </Border.Effect>
                <DockPanel>
                    <TextBox x:Name="PaletteBox" DockPanel.Dock="Top" FontSize="15" Padding="10,8"
                             Text="{Binding PaletteQuery, UpdateSourceTrigger=PropertyChanged}"
                             PreviewKeyDown="PaletteBox_KeyDown"
                             ToolTip="Type a command…"/>
                    <ListBox x:Name="PaletteList" Style="{StaticResource GList}" Margin="0,8,0,0" MaxHeight="380"
                             ItemsSource="{Binding PaletteResults}"
                             SelectedIndex="{Binding PaletteSelectedIndex}"
                             SelectionChanged="PaletteList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Background="Transparent" MouseLeftButtonUp="PaletteItem_Click">
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding Gesture}"
                                               Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="12,0,4,0"/>
                                    <TextBlock Text="{Binding Name}" Style="{StaticResource Body}"
                                               FontSize="13" Margin="4,3"/>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
