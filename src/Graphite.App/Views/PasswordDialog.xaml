<Window x:Class="Graphite.App.Views.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner" SizeToContent="Height" Width="380"
        WindowStyle="ToolWindow" ResizeMode="NoResize" ShowInTaskbar="False"
        Background="{DynamicResource App.BackgroundBrush}"
        TextElement.Foreground="{DynamicResource App.TextBrush}"
        FontFamily="Segoe UI Variable, Segoe UI" FontSize="12.5">
    <StackPanel Margin="20">
        <TextBlock x:Name="PromptText" Style="{StaticResource Body}" TextWrapping="Wrap" Margin="0,0,0,10"/>
        <PasswordBox x:Name="ValueBox" FontSize="14" Padding="6,5"
                     Background="{DynamicResource App.CardBrush}"
                     Foreground="{DynamicResource App.TextBrush}"
                     BorderBrush="{DynamicResource App.StrokeBrush}"/>
        <TextBlock x:Name="ErrorText" Style="{StaticResource Caption}" Foreground="#C24444"
                   Margin="2,6,0,0" Visibility="Collapsed"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Style="{StaticResource GhostButton}" Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="OK" Style="{StaticResource AccentButton}" IsDefault="True" Click="Ok_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
